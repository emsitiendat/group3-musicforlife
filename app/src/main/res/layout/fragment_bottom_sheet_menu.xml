<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_modern"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@color/text_secondary"
        android:alpha="0.5"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:paddingHorizontal="24dp"
        android:text="Tùy chọn bài hát"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/item_playlist"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:text="Thêm vào Playlist"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:drawableStartCompat="@drawable/ic_playlist_add"
                app:drawableTint="@color/text_primary"
                android:drawablePadding="16dp" />

            <TextView
                android:id="@+id/item_view_artist"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:text="Xem nghệ sĩ"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:drawableStartCompat="@drawable/ic_person"
                app:drawableTint="@color/text_primary"
                android:drawablePadding="16dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="24dp" android:layout_marginVertical="8dp" android:background="#1AFFFFFF" />

            <TextView
                android:id="@+id/item_share_community"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:text="Chia sẻ lên Cộng đồng"
                android:textColor="@color/color_accent"
                android:textSize="16sp"
                android:textStyle="bold"
                app:drawableStartCompat="@drawable/ic_lyrics"
                app:drawableTint="@color/color_accent"
                android:drawablePadding="16dp" />

            <TextView
                android:id="@+id/item_share_story"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:text="Chia sẻ lên Story"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:drawableStartCompat="@drawable/ic_share"
                app:drawableTint="@color/text_primary"
                android:drawablePadding="16dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="24dp" android:layout_marginVertical="8dp" android:background="#1AFFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:text="Tốc độ phát nhạc"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="24dp"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/layout_quick_speeds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="16dp" />
            </HorizontalScrollView>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="24dp" android:layout_marginVertical="8dp" android:background="#1AFFFFFF" />

            <TextView
                android:id="@+id/item_timer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:text="Hẹn giờ tắt nhạc"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:drawableStartCompat="@drawable/ic_timer"
                app:drawableTint="@color/text_primary"
                android:drawablePadding="16dp" />

            <TextView
                android:id="@+id/item_zen_mode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:text="Chế độ Zen"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                app:drawableStartCompat="@drawable/ic_zen_mode"
                app:drawableTint="@color/text_primary"
                android:drawablePadding="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>