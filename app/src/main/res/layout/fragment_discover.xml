<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/discover_root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:clickable="true"
    android:focusable="true"> <ImageButton
    android:id="@+id/btn_close_discover"
    android:layout_width="48dp"
    android:layout_height="48dp"
    android:layout_margin="16dp"
    android:layout_marginTop="48dp"
    android:background="@android:color/transparent"
    android:src="@drawable/ic_arrow_down"
    android:rotation="90"
    android:scaleType="centerInside"
    android:padding="12dp"
    app:tint="@color/text_primary"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tv_discover_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Khám phá nhạc mới"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_close_discover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_close_discover" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"
        app:layout_constraintBottom_toTopOf="@id/layout_discover_controls"
        app:layout_constraintTop_toBottomOf="@id/tv_discover_header">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_discover_cards"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progress_bar_discover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/color_accent"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_empty_discover"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Đã xem hết gợi ý.\nHãy quay lại sau nhé!"
            android:textAlignment="center"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_discover_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/btn_refresh_discover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btn_swipe_left"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="#1AFFFFFF"
            android:src="@drawable/ic_close"
            android:padding="22dp"
            android:scaleType="centerInside"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btn_discover_play"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="#1AFFFFFF"
            android:src="@drawable/ic_play_white"
            android:padding="16dp"
            android:scaleType="centerInside"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btn_swipe_right"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginStart="24dp"
            android:background="@drawable/bg_circle_white"
            android:backgroundTint="#1AFFFFFF"
            android:src="@drawable/ic_heart_filled"
            android:padding="22dp"
            android:scaleType="centerInside"
            app:tint="#FF5252" />
    </LinearLayout>

    <TextView
        android:id="@+id/btn_refresh_discover"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="48dp"
        android:background="@drawable/bg_circle_white"
        android:backgroundTint="#1AFFFFFF"
        android:text="Tìm thêm bài hát"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>