<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/player_main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/img_player_bg_blur"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.4" />

    <View
        android:id="@+id/player_color_scrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_player_gradient" />

    <ImageButton
        android:id="@+id/btn_collapse_player"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_down"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurface" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="@+id/btn_collapse_player"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btn_collapse_player">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SOCIAL PLAYER"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_live_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="TRỰC TIẾP"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/btn_player_more"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="24dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurface" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/img_player_cover"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"
        android:scaleType="centerCrop"
        android:src="@drawable/default_cover"
        android:elevation="12dp"
        android:transitionName="cover_image_transition"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@+id/btn_collapse_player"
        app:layout_constraintBottom_toTopOf="@+id/layout_title_heart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize16dp" />

    <LinearLayout
        android:id="@+id/layout_social_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@drawable/bg_circle_translucent"
        android:elevation="13dp"
        app:layout_constraintBottom_toBottomOf="@+id/img_player_cover"
        app:layout_constraintStart_toStartOf="@+id/img_player_cover"
        app:layout_constraintEnd_toEndOf="@+id/img_player_cover">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_person"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tv_player_listening_now"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="3.542 đang cùng nghe"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_live_reactions"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:elevation="30dp"
        app:layout_constraintBottom_toBottomOf="@+id/img_player_cover"
        app:layout_constraintStart_toStartOf="@+id/img_player_cover"
        app:layout_constraintEnd_toEndOf="@+id/img_player_cover" />

    <LinearLayout
        android:id="@+id/layout_title_heart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@+id/seek_bar_player">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/tv_player_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:text="Tên bài hát"
                android:textColor="?attr/colorOnSurface"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_player_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Ca sĩ"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="16sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_player_heart"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_heart_outline"
            android:scaleType="centerInside"
            app:tint="@color/color_accent" />
    </LinearLayout>

    <SeekBar
        android:id="@+id/seek_bar_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:progressTint="?attr/colorOnSurface"
        android:thumbTint="@color/color_accent"
        app:layout_constraintBottom_toTopOf="@+id/tv_player_current_time" />

    <TextView
        android:id="@+id/tv_player_current_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginBottom="24dp"
        android:text="0:00"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/layout_controls" />

    <TextView
        android:id="@+id/tv_player_total_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="24dp"
        android:text="0:00"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/layout_controls" />

    <LinearLayout
        android:id="@+id/layout_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/layout_social_actions">

        <ImageButton
            android:id="@+id/btn_player_shuffle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_shuffle"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btn_player_prev"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_prev_white"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btn_player_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/bg_circle_solid"
            android:backgroundTint="?attr/colorOnSurface"
            android:src="@drawable/ic_play_white"
            android:elevation="6dp"
            android:padding="16dp"
            android:scaleType="centerInside"
            app:tint="?attr/colorSurface" />

        <ImageButton
            android:id="@+id/btn_player_next"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_next_white"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btn_player_repeat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_repeat"
            app:tint="?attr/colorOnSurface" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_social_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btn_player_lyrics"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_lyrics"
            android:scaleType="centerInside"
            app:tint="?attr/colorOnSurfaceVariant" />

        <ImageButton
            android:id="@+id/btn_player_comments"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_comment"
            android:scaleType="centerInside"
            app:tint="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btn_player_share"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_share"
            android:scaleType="centerInside"
            app:tint="?attr/colorOnSurface" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_zen_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:visibility="gone"
        android:elevation="100dp">

        <TextView
            android:id="@+id/tv_zen_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25:00"
            android:textColor="?attr/colorPrimary"
            android:textSize="80sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.35" />

        <TextView
            android:id="@+id/tv_zen_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Đang trong vùng tập trung..."
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_zen_timer" />

        <TextView
            android:id="@+id/tv_zen_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="Hãy tập trung vào hiện tại..."
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="italic"
            android:alpha="0.75"
            android:lineSpacingExtra="4dp"
            app:layout_constraintTop_toBottomOf="@+id/tv_zen_message" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_stop_zen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="64dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:text="Kết thúc sớm"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingHorizontal="32dp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>