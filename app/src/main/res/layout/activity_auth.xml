<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/img_auth_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.15" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/scrim_black_bottom" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="80dp"
                android:text="Music For Life"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textSize="36sp"
                android:letterSpacing="-0.02"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Giao thoa của Âm nhạc và Cảm xúc"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp">

                <LinearLayout
                    android:id="@+id/layout_login_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_login_username"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tên đăng nhập"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/bg_surface"
                        app:boxStrokeColor="@color/color_accent"
                        app:boxStrokeWidth="1dp"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/text_secondary"
                        app:errorEnabled="true"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:paddingVertical="16dp"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_login_password"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mật khẩu"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/bg_surface"
                        app:boxStrokeColor="@color/color_accent"
                        app:boxStrokeWidth="1dp"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp"
                        app:startIconDrawable="@drawable/ic_lock_white"
                        app:startIconTint="@color/text_secondary"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/text_secondary"
                        app:errorEnabled="true"
                        android:layout_marginBottom="24dp"> <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/plus_jakarta_sans_medium"
                        android:paddingVertical="16dp"
                        android:inputType="textPassword"
                        android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_auth_login"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Đăng nhập"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        app:cornerRadius="30dp"
                        app:backgroundTint="@color/color_accent"
                        android:layout_marginBottom="16dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_register_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_name"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Họ và tên"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/bg_surface"
                        app:boxStrokeColor="@color/color_accent"
                        app:boxStrokeWidth="1dp"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/text_secondary"
                        app:errorEnabled="true"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:paddingVertical="16dp"
                            android:inputType="textPersonName"
                            android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_username"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tên đăng nhập"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/bg_surface"
                        app:boxStrokeColor="@color/color_accent"
                        app:boxStrokeWidth="1dp"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/text_secondary"
                        app:errorEnabled="true"
                        android:layout_marginBottom="4dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:paddingVertical="16dp"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_register_password"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mật khẩu"
                        app:hintTextColor="@color/text_secondary"
                        app:boxBackgroundColor="@color/bg_surface"
                        app:boxStrokeColor="@color/color_accent"
                        app:boxStrokeWidth="1dp"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusBottomEnd="24dp"
                        app:startIconDrawable="@drawable/ic_lock_white"
                        app:startIconTint="@color/text_secondary"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/text_secondary"
                        app:errorEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/plus_jakarta_sans_medium"
                            android:paddingVertical="16dp"
                            android:inputType="textPassword"
                            android:maxLines="1"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_auth_register"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Đăng ký"
                        android:fontFamily="@font/plus_jakarta_sans_bold"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        app:cornerRadius="30dp"
                        app:backgroundTint="@color/color_accent"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="40dp"> <TextView
                android:id="@+id/tv_auth_switch_prompt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa có tài khoản?"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"/>

                <TextView
                    android:id="@+id/tv_auth_switch_action"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Đăng ký ngay"
                    android:textColor="@color/color_accent"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layout_global_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E6121212"
        android:gravity="center"
        android:orientation="vertical"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:indeterminateTint="@color/color_accent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Đang xử lý..."
            android:textColor="#B3FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</FrameLayout>