<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_modern"
    android:orientation="vertical"
    android:paddingBottom="24dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@color/text_secondary"
        android:alpha="0.5"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Chỉnh sửa Playlist"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                android:gravity="center_vertical">

                <FrameLayout
                    android:id="@+id/layout_edit_cover"
                    android:layout_width="80dp"
                    android:layout_height="80dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/img_edit_preview"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/bg_surface_hover"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music"
                        app:tint="@color/text_secondary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize8dp" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_circle_white"
                        android:backgroundTint="#80000000"
                        android:padding="4dp"
                        android:src="@drawable/ic_edit"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="52dp"
                    android:layout_marginStart="16dp"
                    app:cardBackgroundColor="@color/bg_surface_hover"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp">

                    <EditText
                        android:id="@+id/et_edit_name"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:hint="Tên Playlist..."
                        android:inputType="textCapSentences"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/bg_surface_hover"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <EditText
                    android:id="@+id/et_edit_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Mô tả Playlist (Tùy chọn)..."
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:padding="16dp"
                    android:minLines="2"
                    android:gravity="top|start"
                    android:textSize="14sp" />
            </androidx.cardview.widget.CardView>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_edit_public"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:text="Công khai Playlist này cho mọi người"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:checked="true"
                app:thumbTint="@color/color_accent"
                app:trackTint="#4DFFFFFF" />

            <TextView
                android:id="@+id/btn_save_playlist"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_circle_white"
                android:backgroundTint="@color/color_accent"
                android:gravity="center"
                android:text="Lưu Thay Đổi"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:background="#1AFFFFFF" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#1AFF5252"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/btn_delete_playlist"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="Xóa Playlist này"
                    android:textColor="@color/color_accent"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="?attr/selectableItemBackground" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>