<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MusicForLife" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item> <item name="colorPrimary">@color/color_accent</item>

        <item name="android:textViewStyle">@style/AppTextViewStyle</item>
        <item name="android:buttonStyle">@style/AppButtonStyle</item>

        <item name="cardViewStyle">@style/AppCardViewStyle</item>
    </style>

    <style name="AppTextViewStyle" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <style name="AppButtonStyle" parent="Widget.Material3.Button">
        <item name="android:fontFamily">@font/plus_jakarta_sans_bold</item>
        <item name="cornerRadius">26dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="AppCardViewStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize8dp" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize16dp" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.MusicForLife" parent="Base.Theme.MusicForLife" />
</resources>